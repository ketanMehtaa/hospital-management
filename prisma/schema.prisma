generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/* ================= ENUMS ================= */

enum Gender {
  Male
  Female
  Other
}

enum MediaType {
  Photo
  Video
}


enum MedicineCategory {
  Antibiotic
  Antihistamine
  Decongestant
  Steroid
  Analgesic
  Antifungal
  EarDrop
  NasalSpray
  ThroatSpray
  Other
}

enum MedicineUnit {
  Strip
  Bottle
  Tube
  Vial
  Sachet
  Tablet
  Capsule
}

enum BillCategory {
  OpdConsultation
  Medicine
  Endoscopy
  Procedure
  HearingTest
  Radiology
  Pathology
}

/* ================= PATIENT ================= */

model Patient {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  age       Int
  gender    Gender
  phone     String?  @unique @db.VarChar(15)
  address   String?  @db.Text
  diagnosis String?  @db.Text

  // ✅ merged date + time
  visitAt   DateTime

  bills     Bill[]
  media     PatientMedia[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? // ✅ soft delete

  @@index([name])
  @@index([phone])
  @@map("patients")
}

/* ================= MEDICINE ================= */

model Medicine {
  id           String           @id @default(uuid()) @db.Uuid
  barcode      String?          @unique @db.VarChar(100)
  name         String           @db.VarChar(255)
  category     MedicineCategory @default(Other)
  unit         MedicineUnit     @default(Strip)

  buyingPrice  Decimal? @map("buying_price") @db.Decimal(10,2)  // legacy / default cost
  sellingPrice Decimal  @map("selling_price") @db.Decimal(10,2)

  minStock     Decimal  @map("min_stock") @default(10) @db.Decimal(10,2)

  // stock, expiryDate, batchNumber moved to MedicineBatch
  batches   MedicineBatch[]
  billItems BillItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime?

  @@index([name])
  @@index([barcode])
  @@map("medicines")
}

/* ================= MEDICINE BATCH ================= */

model MedicineBatch {
  id            String   @id @default(uuid()) @db.Uuid

  medicineId    String   @db.Uuid
  medicine      Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  batchNumber   String?  @map("batch_number") @db.VarChar(100)
  expiryDate    DateTime? @map("expiry_date") @db.Date

  quantity      Decimal  @db.Decimal(10,2)         // remaining units in this batch
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(10,2)

  billItems BillItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([medicineId])
  @@index([expiryDate])
  @@map("medicine_batches")
}

/* ================= BILL ================= */

model Bill {
  id          String   @id @default(uuid()) @db.Uuid
  billNumber  String   @unique @map("bill_number") @db.VarChar(50)

  patientId   String?  @map("patient_id") @db.Uuid

  // ✅ snapshot (intentional, renamed for clarity)
  patientName String   @map("patient_name") @db.VarChar(255)
  phone       String?  @db.VarChar(15)

  // ✅ merged date + time
  billAt      DateTime @map("bill_at")

  // ❗ FIXED: Decimal
  discount    Decimal  @default(0) @db.Decimal(10,2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(10,2)

  // ✅ payment split
  paidCash    Decimal  @default(0) @map("paid_cash") @db.Decimal(10,2)
  paidOnline  Decimal  @default(0) @map("paid_online") @db.Decimal(10,2)

  patient Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  items   BillItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? // ✅ soft delete

  @@index([patientId])
  @@index([billAt])
  @@index([billNumber])
  @@map("bills")
}

/* ================= BILL ITEM ================= */

model BillItem {
  id          String       @id @default(uuid()) @db.Uuid
  billId      String       @map("bill_id") @db.Uuid
  category    BillCategory
  description String       @db.VarChar(255)

  // ❗ FIXED: Decimal
  quantity    Decimal      @default(1) @db.Decimal(10,2)
  unitPrice   Decimal      @map("unit_price") @db.Decimal(10,2)
  amount      Decimal      @db.Decimal(10,2)

  medicineId String?   @map("medicine_id") @db.Uuid
  medicine   Medicine? @relation(fields: [medicineId], references: [id], onDelete: SetNull)

  batchId String?        @map("batch_id") @db.Uuid
  batch   MedicineBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([medicineId])
  @@index([batchId])
  @@map("bill_items")
}

/* ================= PATIENT MEDIA ================= */

model PatientMedia {
  id          String    @id @default(uuid()) @db.Uuid

  patientId   String    @map("patient_id") @db.Uuid
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  objectKey   String    @map("object_key") @db.VarChar(500)
  filename    String    @db.VarChar(255)
  mimeType    String    @map("mime_type") @db.VarChar(100)
  sizeBytes   Int       @map("size_bytes")
  mediaType   MediaType

  capturedAt  DateTime  @map("captured_at")
  description String?   @db.Text

  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([patientId])
  @@map("patient_media")
}